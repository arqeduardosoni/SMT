{
  "appId": "mx.smt.tennis",
  "appName": "SMT",
  "webDir": "dist",
  "bundledWebRuntime": false,
  "backgroundColor": "#040A18",
  "ios": {
    "contentInset": "always",
    "backgroundColor": "#040A18"
  },
  "android": {
    "backgroundColor": "#040A18",
    "allowMixedContent": true
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 1500,
      "launchAutoHide": true,
      "backgroundColor": "#040A18",
      "showSpinner": false,
      "splashFullScreen": true,
      "splashImmersive": true
    },
    "StatusBar": {
      "style": "dark",
      "backgroundColor": "#040A18"
    },
    "Keyboard": {
      "resize": "body",
      "style": "dark",
      "resizeOnFullScreen": true
    }
  }
}
